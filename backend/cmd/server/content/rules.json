{
  "version": 2,
  "presets": {
    "source_types": [
      { "value": "Credit Card", "origin": "predefined" },
      { "value": "Debit Card", "origin": "predefined" },
      { "value": "UPI", "origin": "predefined" },
      { "value": "Mobile App", "origin": "predefined" },
      { "value": "NetBanking", "origin": "predefined" }
    ],
    "banks": [
      { "value": "Axis", "origin": "predefined" },
      { "value": "HDFC", "origin": "predefined" },
      { "value": "ICICI", "origin": "predefined" }
    ]
  },
  "rules": [
    {
      "name": "ICICI Credit Card",
      "sender_emails": ["credit_cards@icicibank.com", "credit_cards@icici.bank.in"],
      "subject_contains": "Transaction alert for your ICICI Bank Credit Card",
      "amount_regex": "(?:INR|USD|EUR) ([\\d,]+(?:\\.\\d+)?)",
      "merchant_regex": "(?:at ([A-Z][A-Z ]*?) on|Info: (.*?)\\.)",
      "currency_regex": "(INR|USD|EUR)",
      "source": { "type": "Credit Card", "label": "ICICI Credit Card", "bank": "ICICI" }
    },
    {
      "name": "HDFC Credit Card",
      "sender_emails": ["alerts@hdfcbank.bank.in", "alerts@hdfcbank.net"],
      "subject_contains": "Alert : Update on your HDFC Bank Credit Card",
      "amount_regex": "Rs\\.\\s*([\\d,]+(?:\\.\\d+)?)",
      "merchant_regex": "\\bat\\b (.*?) on",
      "currency_regex": "",
      "source": { "type": "Credit Card", "label": "HDFC Credit Card", "bank": "HDFC" }
    },
    {
      "name": "HDFC Credit Card Debit Alert",
      "sender_emails": ["alerts@hdfcbank.bank.in", "alerts@hdfcbank.net"],
      "subject_contains": "debited via Credit Card",
      "amount_regex": "Rs\\.\\s*([\\d,]+(?:\\.\\d+)?)",
      "merchant_regex": "\\btowards\\b (.*?) on",
      "currency_regex": "",
      "source": { "type": "Credit Card", "label": "HDFC Credit Card", "bank": "HDFC" }
    },
    {
      "name": "HDFC Credit Card Payment Made",
      "sender_emails": ["alerts@hdfcbank.bank.in", "alerts@hdfcbank.net"],
      "subject_contains": "A payment was made using your Credit Card",
      "amount_regex": "Rs\\.\\s*([\\d,]+(?:\\.\\d+)?)",
      "merchant_regex": "\\btowards\\b (.*?) on",
      "currency_regex": "",
      "source": { "type": "Credit Card", "label": "HDFC Credit Card", "bank": "HDFC" }
    },
    {
      "name": "HDFC UPI",
      "sender_emails": ["alerts@hdfcbank.bank.in", "alerts@hdfcbank.net"],
      "subject_contains": "UPI txn",
      "amount_regex": "Rs\\.\\s*([\\d,]+(?:\\.\\d+)?)",
      "merchant_regex": "VPA \\S+\\s+(?:\\(([^)]*)\\)|(.*?))\\s+on\\s",
      "currency_regex": "",
      "source": { "type": "UPI", "label": "HDFC UPI", "bank": "HDFC" }
    },
    {
      "name": "Axis Bank Credit Card",
      "sender_emails": ["alerts@axis.bank.in"],
      "subject_contains": "spent on credit card",
      "amount_regex": "Transaction Amount:\\s*</div>\\s*<div[^>]*>\\s*[A-Z]{3}\\s*(?:&nbsp;|\\s)*([\\d,.]+)",
      "merchant_regex": "Merchant Name:\\s*</div>\\s*<div[^>]*>\\s*(.*?)\\s*(?:<br\\s*/?>|\\s*</div>)",
      "currency_regex": "Transaction Amount:\\s*</div>\\s*<div[^>]*>\\s*([A-Z]{3})",
      "source": { "type": "Credit Card", "label": "Axis Bank Credit Card", "bank": "Axis" }
    },
    {
      "name": "ICICI iMobile Fund Transfer",
      "sender_emails": ["customercare@icicibank.com"],
      "subject_contains": "Alert for transaction through ICICI Bank iMobile",
      "amount_regex": "Rs ([\\d,]+(?:\\.\\d+)?)",
      "merchant_regex": "towards (.*?) on",
      "currency_regex": "",
      "source": { "type": "Mobile App", "label": "ICICI iMobile", "bank": "ICICI" }
    },
    {
      "name": "ICICI NEFT iMobile",
      "sender_emails": ["customernotification@icici.bank.in"],
      "subject_contains": "NEFT transaction through ICICI Bank iMobile.",
      "amount_regex": "Rs\\.\\s*([\\d,]+(?:\\.\\d+)?)",
      "merchant_regex": "towards (.*?) on",
      "currency_regex": "",
      "source": { "type": "Mobile App", "label": "ICICI iMobile", "bank": "ICICI" }
    },
    {
      "name": "ICICI Debit Card",
      "sender_emails": ["alert@icicibank.com"],
      "subject_contains": "Transaction alert for your ICICI Bank debit card",
      "amount_regex": "Rs\\.\\s*([\\d,]+(?:\\.\\d+)?)",
      "merchant_regex": "Info:\\s*(.*?)\\.",
      "currency_regex": "",
      "source": { "type": "Debit Card", "label": "ICICI Debit Card", "bank": "ICICI" }
    }
  ]
}
