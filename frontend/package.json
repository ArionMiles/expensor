{
  "name": "expensor-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cover": "vitest run --coverage",
    "test:e2e": "PLAYWRIGHT_ARTIFACT_PREFIX=mocked playwright test --project=mocked",
    "test:e2e:smoke": "PLAYWRIGHT_ARTIFACT_PREFIX=smoke playwright test --project=smoke",
    "screenshot:readme": "PLAYWRIGHT_ARTIFACT_PREFIX=screenshots playwright test --project=screenshots",
    "screenshot:live": "node scripts/capture-live-screenshots.mjs",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.56.2",
    "axios": "^1.14.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^1.7.0",
    "react": "^18.3.1",
    "react-day-picker": "^9.14.0",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2",
    "tailwind-merge": "^2.5.2"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@playwright/test": "^1.55.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^3.2.4",
    "autoprefixer": "^10.4.20",
    "jsdom": "^26.1.0",
    "msw": "^2.11.2",
    "postcss": "^8.4.45",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^3.4.11",
    "typescript": "^5.5.3",
    "vite": "^8.0.3",
    "vitest": "^3.2.4",
    "vitest-axe": "^0.1.0"
  }
}
